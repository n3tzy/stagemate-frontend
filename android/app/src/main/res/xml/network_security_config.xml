<?xml version="1.0" encoding="utf-8"?>
<!--
  Release 빌드용 네트워크 보안 설정
  - HTTP 평문 통신 완전 차단 (HTTPS만 허용)
  - 사용자 설치 CA 불신 (시스템 CA만 신뢰)
-->
<network-security-config>
  <base-config cleartextTrafficPermitted="false">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>
</network-security-config>
